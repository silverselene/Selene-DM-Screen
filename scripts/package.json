{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:spells": "tsx ./src/data-generators/generate-spells.ts",
    "generate:monsters": "tsx ./src/data-generators/generate-monsters.ts",
    "generate:weapons": "tsx ./src/data-generators/generate-weapons.ts",
    "generate:compendium": "tsx ./src/data-generators/generate-compendium.ts",
    "generate:all": "tsx ./src/data-generators/generate-spells.ts && tsx ./src/data-generators/generate-monsters.ts && tsx ./src/data-generators/generate-weapons.ts && tsx ./src/data-generators/generate-compendium.ts"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
