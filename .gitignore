# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
*.tsbuildinfo

# dependencies
node_modules

# test output
coverage

# secrets — the ai-bridge reads ANTHROPIC_API_KEY / CLAUDE_CODE_OAUTH_TOKEN from
# the environment; keep .dockerignore's secret patterns in sync with these.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# IDEs and editors
/.idea
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
npm-debug.log
yarn-error.log

# System Files
.DS_Store
Thumbs.db

# Local-only working docs (not part of the repo)
/MANUAL-TESTS-post-rebase.md
